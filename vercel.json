{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "excludeFiles": "public/images/**"
    }
  },
  "routes": [
    { "src": "/build/(.*)", "dest": "/build/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/favicon\\.(.*)", "dest": "/favicon.$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "overrides": {
    "build/*": { "headers": { "cache-control": "public, max-age=31536000, immutable" } }
  },
  "buildCommand": "VERCEL_ANALYZE_BUILD_OUTPUT=1 npm ci && npm run build",
  "outputDirectory": "public"
}
