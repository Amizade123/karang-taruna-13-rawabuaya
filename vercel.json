{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "excludeFiles": "public/images/**"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ],
  "buildCommand": "VERCEL_ANALYZE_BUILD_OUTPUT=1 npm ci && npm run build",
  "outputDirectory": "public"
}
